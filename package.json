{
  "name": "website",
  "version": "1.0.0",
  "description": "Este repositorio contiene el código fuente del sitio web oficial de Finca Termópilas, ubicada en Rivera, Huila, Colombia.",
  "main": "dist/main.js",
  "scripts": {
    "build": "webpack && node scripts/update-sw-version.js",
    "watch": "webpack --watch",
    "lint": "eslint src/ scripts/ --max-warnings 0",
    "lint:appscript": "eslint appscript/ --max-warnings 999",
    "process-blog": "npm run build && node scripts/process-blog.js",
    "process-blog-single": "npm run build && node scripts/process-blog.js",
    "config:inject": "node scripts/inject-ga-from-config.js",
    "sitemap:generate": "node scripts/generate-sitemap.js",
    "sitemap:validate": "node -e \"require('fs').readFileSync('sitemap.xml','utf8'); console.log('sitemap.xml readable')\"",
    "sitemap:ping": "node -e \"const https=require('https');const u=['https://www.google.com/ping?sitemap=https://termopilas.co/sitemap.xml','https://www.bing.com/ping?sitemap=https://termopilas.co/sitemap.xml'];u.forEach(x=>https.get(x, r=>console.log(x, r.statusCode)));\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/termopilashuila/website.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/termopilashuila/website/issues"
  },
  "homepage": "https://github.com/termopilashuila/website#readme",
  "devDependencies": {
    "eslint": "^9.39.2",
    "globals": "^17.3.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.54.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@types/marked": "^5.0.2",
    "gray-matter": "^4.0.3",
    "marked": "^16.1.1",
    "sharp": "^0.33.5"
  }
}
